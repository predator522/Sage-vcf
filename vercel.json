{
    "version": 2,
    "builds": [
        {
            "src": "index.html",
            "use": "@vercel/static"
        },
        {
            "src": "api/*.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "env": {
        "MONGODB_URI": "your_mongodb_atlas_connection_string",
        "ADMIN_PASSWORD": "kingkwesi",
        "JWT_SECRET": "heis"
    }
} 
